<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_alarm_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="28dp"
        android:paddingTop="60dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏰"
            android:textSize="64sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvAlarmTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="#AAFFFFFF"
            android:layout_marginBottom="10dp"
            android:text="09:00 AM  •  Mon, 01 Jan" />

        <TextView
            android:id="@+id/tvAlarmTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:textAlignment="center"
            android:layout_marginBottom="10dp"
            android:maxLines="3"
            android:ellipsize="end"
            android:text="Reminder" />

        <TextView
            android:id="@+id/tvAlarmDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#BBFFFFFF"
            android:textAlignment="center"
            android:maxLines="3"
            android:ellipsize="end"
            android:layout_marginBottom="36dp"
            android:text="" />

        <!-- SNOOZE label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SNOOZE FOR"
            android:textSize="11sp"
            android:textColor="#88FFFFFF"
            android:letterSpacing="0.15"
            android:layout_marginBottom="10dp" />

        <!-- Row 1: 15m and 30m -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSnooze1"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="15 min"
                android:textSize="14sp"
                android:textColor="@color/white"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/white"
                app:strokeWidth="1dp"
                app:cornerRadius="26dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSnooze2"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="30 min"
                android:textSize="14sp"
                android:textColor="@color/white"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/white"
                app:strokeWidth="1dp"
                app:cornerRadius="26dp" />

        </LinearLayout>

        <!-- Row 2: 1 hour and 2 hours -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSnooze3"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="1 hour"
                android:textSize="14sp"
                android:textColor="@color/white"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/white"
                app:strokeWidth="1dp"
                app:cornerRadius="26dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSnooze4"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="2 hours"
                android:textSize="14sp"
                android:textColor="@color/white"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/white"
                app:strokeWidth="1dp"
                app:cornerRadius="26dp" />

        </LinearLayout>

        <!-- Custom date/time snooze -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSnoozeCustom"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="24dp"
            android:text="📅  Custom Date &amp; Time"
            android:textSize="14sp"
            android:textColor="@color/accent_light"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/accent_light"
            app:strokeWidth="1dp"
            app:cornerRadius="26dp" />

        <!-- COMPLETE / DISMISS button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDismiss"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="16dp"
            android:text="✓  COMPLETE"
            android:textSize="16sp"
            android:textColor="@color/white"
            app:backgroundTint="@color/accent"
            app:cornerRadius="28dp" />

    </LinearLayout>

</ScrollView>
