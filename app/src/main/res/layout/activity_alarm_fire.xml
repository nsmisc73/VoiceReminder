<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_alarm_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="28dp"
        android:paddingTop="60dp">

        <!-- Bell icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏰"
            android:textSize="@dimen/alarm_icon_size"
            android:layout_marginBottom="16dp" />

        <!-- Current time -->
        <TextView
            android:id="@+id/tvAlarmTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="#AAFFFFFF"
            android:layout_marginBottom="10dp"
            android:text="09:00 AM  •  Mon, 01 Jan" />

        <!-- Reminder title -->
        <TextView
            android:id="@+id/tvAlarmTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/alarm_title_size"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:textAlignment="center"
            android:layout_marginBottom="10dp"
            android:maxLines="3"
            android:ellipsize="end"
            android:text="Call John" />

        <!-- Description (original voice text) -->
        <TextView
            android:id="@+id/tvAlarmDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#BBFFFFFF"
            android:textAlignment="center"
            android:maxLines="3"
            android:ellipsize="end"
            android:layout_marginBottom="40dp"
            android:text="" />

        <!-- Snooze label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/snooze_label"
            android:textSize="11sp"
            android:textColor="#88FFFFFF"
            android:letterSpacing="0.15"
            android:layout_marginBottom="12dp" />

        <!-- 4 snooze buttons in a 2x2 grid -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="4"
            android:layout_marginBottom="36dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSnooze1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:text="15m"
                android:textColor="@color/white"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSnooze2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:text="30m"
                android:textColor="@color/white"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSnooze3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:text="1h"
                android:textColor="@color/white"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSnooze4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:text="@string/custom"
                android:textColor="@color/accent_light"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/accent_light" />

        </GridLayout>

        <!-- Dismiss button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDismiss"
            android:layout_width="220dp"
            android:layout_height="56dp"
            android:text="@string/btn_dismiss"
            android:textSize="16sp"
            android:textColor="@color/white"
            app:backgroundTint="@color/accent"
            app:cornerRadius="28dp" />

    </LinearLayout>

</ScrollView>
